generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model HeroTitle {
  id        String @id @default(uuid())
  title     String
  sortOrder Int
}

model HeroSkillBadge {
  id        String @id @default(uuid())
  name      String
  iconKey   String
  sortOrder Int
}

model SocialLink {
  id        String  @id @default(uuid())
  name      String
  href      String
  iconKey   String
  detail    String?
  sortOrder Int
}

model AboutParagraph {
  id        String @id @default(uuid())
  content   String
  sortOrder Int
}

enum ScoreType {
  CGPA
  PERCENTAGE
}

model Education {
  id          String     @id @default(uuid())
  institution String
  location    String
  degree      String
  scoreType   ScoreType?
  score       String?
  scoreTotal  String?
  startYear   String
  endYear     String
  sortOrder   Int
}

model Skill {
  id          String       @id @default(uuid())
  name        String
  iconKey     String
  show        Boolean      @default(true)
  sortOrder   Int
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  experiences Experience[]
  projects    Project[]
}

model Experience {
  id           String             @id @default(uuid())
  company      String
  position     String
  location     String
  startDate    String
  endDate      String
  isCurrent    Boolean            @default(false)
  website      String?
  sortOrder    Int
  bullets      ExperienceBullet[]
  skills       Skill[]
}

model ExperienceBullet {
  id           String     @id @default(uuid())
  content      String
  sortOrder    Int
  experienceId String
  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
}

model Project {
  id        String          @id @default(uuid())
  title     String
  summary   String
  github    String?
  live      String?
  images    String[]
  sortOrder Int
  bullets   ProjectBullet[]
  skills    Skill[]
}

model ProjectBullet {
  id        String  @id @default(uuid())
  content   String
  sortOrder Int
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

enum ImageOrientation {
  LANDSCAPE
  PORTRAIT
  SQUARE
}

model Blog {
  id               String           @id @default(uuid())
  slug             String           @unique
  title            String
  description      String
  content          String
  image            String
  imageOrientation ImageOrientation @default(LANDSCAPE)
  color            String
  show             Boolean          @default(true)
  sortOrder        Int
  publishedAt      DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Quote {
  id     String @id @default(uuid())
  quote  String
  author String
}

model ContactPurpose {
  id        String @id @default(uuid())
  label     String
  emoji     String
  sortOrder Int
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  purpose   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SiteConfig {
  id    String @id @default(uuid())
  key   String @unique
  value String
}

enum AdminRole {
  OWNER
  ADMIN
}

model AdminUser {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String
  role      AdminRole @default(ADMIN)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}
